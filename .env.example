# Database (matches docker/docker-compose.yml defaults)
DATABASE_URL="postgresql://lems_admin:lems_password@localhost:5432/lems_local"

# Solana RPC Endpoints (comma-separated for failover)
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
# SOLANA_RPC_FALLBACK_1="https://your-helius-endpoint.com"
# SOLANA_RPC_FALLBACK_2="https://your-quicknode-endpoint.com"

# Master Treasury Private Key (Base58 encoded)
# CRITICAL: Never commit the actual key. Load from secrets manager in production.
MASTER_TREASURY_PRIVATE_KEY="your-base58-private-key-here"
